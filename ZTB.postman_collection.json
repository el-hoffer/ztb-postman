	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"packages": {},
				"requests": {},
				"exec": [
					"const base = pm.collectionVariables.get(\"apiEndpoint\");",
					"if (!base) throw new Error(\"Missing collection variable: apiEndpoint\");",
					"const authUrl = `${base.replace(/\\/$/, \"\")}/v3/api-key-auth/login`;",
					"",
					"",
					"const SKEW_MS = 30 * 1000;",
					"const ONE_HOUR_MS = 60 * 60 * 1000;",
					"",
					"function tokenValid() {",
					"  const token = pm.collectionVariables.get(\"accessToken\");",
					"  const expiresAt = Number(pm.collectionVariables.get(\"tokenExpires\") || 0);",
					"  return token && expiresAt && (Date.now() + SKEW_MS) < expiresAt;",
					"}",
					"",
					"if (!tokenValid()) {",
					"  const apiKey = pm.collectionVariables.get(\"apiKey\");",
					"  if (!apiKey) throw new Error(\"Missing collection variable: apiKey\");",
					"",
					"  pm.sendRequest({",
					"    url: authUrl,",
					"    method: \"POST\",",
					"    header: { \"Content-Type\": \"application/json\", \"Accept\": \"application/json\" },",
					"    body: { mode: \"raw\", raw: JSON.stringify({ api_key: apiKey }) }",
					"  }, (err, res) => {",
					"    if (err) throw err;",
					"    if (!res || res.code >= 400) throw new Error(`Auth failed: HTTP ${res && res.code} - ${res && res.text()}`);",
					"",
					"    const data = res.json();",
					"    const token = data?.result?.delegate_token;",
					"    if (!token) throw new Error(\"Auth response missing result.delegate_token\");",
					"",
					"    pm.collectionVariables.set(\"accessToken\", token);",
					"    pm.collectionVariables.set(\"tokenExpires\", String(Date.now() + ONE_HOUR_MS));",
					"",
					"    // rerun the original request",
					"    postman.setNextRequest(pm.info.requestName);",
					"  });",
					"",
					"  // stop current request until token is fetched",
					"  postman.setNextRequest(null);",
					"}"
				]
			}
		},
