	"item": [
		{
			"name": "Fetch Template ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Pull templateName from the CSV data file (column: templateName)",
							"const targetName = pm.iterationData.get(\"templateName\");",
							"",
							"pm.test(\"CSV provides templateName\", function () {",
							"  pm.expect(targetName, \"Missing CSV column 'templateName' for this iteration\").to.be.a(\"string\").and.not.empty;",
							"});",
							"",
							"// Parse response",
							"const body = pm.response.json();",
							"",
							"// Find matching template by name",
							"const match = (body.result || []).find(o => o && o.name === targetName);",
							"",
							"pm.test(`Template \"${targetName}\" exists`, function () {",
							"  pm.expect(match, `No object found with name \"${targetName}\"`).to.exist;",
							"  pm.expect(match.id, \"Matched object missing 'id'\").to.be.a(\"string\").and.not.empty;",
							"});",
							"",
							"// Set environment variable",
							"if (match && match.id) {",
							"  pm.environment.set(\"templateId\", match.id);",
							"  console.log(`templateId set for \"${targetName}\":`, match.id);",
							"}"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{apiEndpoint}}/v3/templates",
					"host": [
						"{{apiEndpoint}}"
					],
					"path": [
						"v3",
						"templates"
					]
				},
				"description": "This request fetches all the configured templates, then matches on the template name as derived from the \"templateName\" variable in the csv data file for the run and sets that template's ID as an env variable."
			},
			"response": []
		},
		{
			"name": "Create Site",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status [${pm.response.code}] -Response includes activation_links array', function () {",
							"  const json = pm.response.json();",
							"",
							"  pm.expect(json, \"Site creation problem: Activation Links not present in repsponse\").to.have.property('activation_links');",
							"  pm.expect(json.activation_links, \"Site creation problem: Activation Links not present in repsponse\").to.be.an('array');",
							"  pm.expect(json.activation_links.length, \"Site creation problem: Activation Links not present in repsponse\").to.be.above(0);",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"packages": {},
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"site_name\": \"{{siteName}}\",\n    \"dhcp_server_ip\": \"{{dhcp1}}\",\n    \"location\": {\n        \"is_existing_location\": false,\n        \"details\": {\n            \"country\": \"{{siteCountry}}\",\n            \"name\": \"{{ziaLocationName}}\"\n        }\n    },\n    \"gateways\": [\n        {\n            \"gateway_name\": \"{{gateway1Name}}\",\n            \"is_wan_dhcp\": false,\n            \"default_gw_ip\": \"{{wan1Gateway}}\",\n            \"wan_ip_address\": \"{{wan1IP}}\",\n            \"wan_subnet_mask\": \"{{wan1CIDRPrefix}}\",\n            \"wan_interface\": \"{{gw1WANInterface}}\"\n        },\n        {\n            \"gateway_name\": \"{{gateway2Name}}\",\n            \"is_wan_dhcp\": false,\n            \"default_gw_ip\": \"{{wan2Gateway}}\",\n            \"wan_ip_address\": \"{{wan2IP}}\",\n            \"wan_subnet_mask\": \"{{wan2CIDRPrefix}}\",\n            \"wan_interface\": \"{{gw2WANInterface}}\"\n        }\n    ],\n    \"private_dns\": \"1.1.1.1,8.8.8.8\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{apiEndpoint}}v3/templates/{{templateId}}/deploy_site",
					"host": [
						"{{apiEndpoint}}v3"
					],
					"path": [
						"templates",
						"{{templateId}}",
						"deploy_site"
					]
				}
			},
			"response": []
		},
